# Exemple de configuration des variables d'environnement
# Copiez ce fichier vers .env pour l'utiliser en local

# API URL (exemple)
VITE_API_URL=https://api.monsite.com

# Clé publique de services tiers (ex: Stripe, Analytics)
VITE_ANALYTICS_ID=G-XXXXXXXXXX

# Configuration de l'environnement
VITE_APP_ENV=development
